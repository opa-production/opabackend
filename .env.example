# Backend Environment Variables

# Database Configuration (PostgreSQL only)
# For production: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:your-password@localhost:5432/car_rental

# Test Database Configuration (PostgreSQL for testing)
TEST_MODE=false
TEST_DATABASE_URL=postgresql+asyncpg://postgres:your-test-password@localhost:5432/car_rental_test

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32-charactersS
ALGORITHM=HS256
# Minutes until access JWT expires. App default if omitted: 43200 (~30 days).
# Admin UI only gets this token (no refresh) — keep this comfortably long for admins.
ACCESS_TOKEN_EXPIRE_MINUTES=43200
# Refresh token lifetime (days). Should exceed the access-token window; default 90.
REFRESH_TOKEN_EXPIRE_DAYS=90

# Supabase Storage Configuration (for media uploads only - NOT for database)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google Auth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# CORS: comma-separated or JSON array. List exact origins (localhost vs 127.0.0.1 are different).
# Live Server: add http://127.0.0.1:5500 and/or http://localhost:5500
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19000,http://localhost:19006,http://127.0.0.1:5500

# Payhero M-Pesa Configuration
PAYHERO_AUTH_TOKEN=your_payhero_basic_auth_token
PAYHERO_CHANNEL_ID=your_payhero_channel_id

# Paystack Card Payments (hosted page — no card data stored on our end)
# Get keys from https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your API base URL — Paystack redirects the user here after payment.
# Must be publicly reachable (not localhost). Use ngrok for local testing.
PAYSTACK_CALLBACK_BASE_URL=https://api.ardena.xyz/api/v1

# Redis Configuration (for caching)
REDIS_URL=redis://localhost:6379

# Security Headers Configuration
HSTS_MAX_AGE=31536000
# Include https://cdn.jsdelivr.net in script-src/style-src/font-src or /docs and /redoc hang loading.
CSP_POLICY=default-src 'self'; img-src 'self' data: https:; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; font-src 'self' data: https://cdn.jsdelivr.net; connect-src 'self' https:; frame-ancestors 'none'

# Must match route: POST /api/v1/mpesa/callback (see app/routers/payments.py)
PAYHERO_CALLBACK_URL=https://your-domain.com/api/v1/mpesa/callback

# Host subscription (M-Pesa STK via same Payhero callback URL as bookings)
HOST_SUB_STARTER_PRICE_KES=3500
HOST_SUB_PREMIUM_PRICE_KES=6500
HOST_SUB_STARTER_DURATION_DAYS=30
HOST_SUB_PREMIUM_DURATION_DAYS=30
# STK: if user does not enter PIN within this window, pending is cleared (can checkout again). 30–600.
HOST_SUB_STK_PENDING_WINDOW_SECONDS=90
# While pending, payment-status polls Payhero GET /transaction-status (callback backup). Set 0 to disable.
HOST_SUB_SYNC_PAYHERO_STATUS=1
