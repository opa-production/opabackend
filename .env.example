# Backend Environment Variables

# Database Configuration
# Use sqlite+aiosqlite for local dev (async SQLAlchemy). Plain sqlite:// is rewritten in app/database.py.
DATABASE_URL=sqlite+aiosqlite:///./car_rental.db

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Supabase Configuration
SUPABASE_URL=https://mvzddrdfkgydoitrblpq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im12emRkcmRma2d5ZG9pdHJibHBxIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc2Njk3NTAyMiwiZXhwIjoyMDgyNTUxMDIyfQ.o0csPVj6MLCNa0_crtBllxl8UgkivrXOjZ08KZUqpg0

# Google Auth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# CORS Configuration (adjust for production)
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19000,http://localhost:19006

# Payhero M-Pesa Configuration
PAYHERO_AUTH_TOKEN=your_payhero_basic_auth_token
PAYHERO_CHANNEL_ID=your_payhero_channel_id

# Redis Configuration (for caching)
REDIS_URL=redis://localhost:6379

# Security Headers Configuration
HSTS_MAX_AGE=31536000
CSP_POLICY=default-src 'self'; img-src 'self' data: https:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https:; frame-ancestors 'none'

# Must match route: POST /api/v1/mpesa/callback (see app/routers/payments.py)
PAYHERO_CALLBACK_URL=https://your-domain.com/api/v1/mpesa/callback

# Host subscription (M-Pesa STK via same Payhero callback URL as bookings)
HOST_SUB_STARTER_PRICE_KES=3500
HOST_SUB_PREMIUM_PRICE_KES=6500
HOST_SUB_STARTER_DURATION_DAYS=30
HOST_SUB_PREMIUM_DURATION_DAYS=30
# STK: if user does not enter PIN within this window, pending is cleared (can checkout again). 30–600.
HOST_SUB_STK_PENDING_WINDOW_SECONDS=90
# While pending, payment-status polls Payhero GET /transaction-status (callback backup). Set 0 to disable.
HOST_SUB_SYNC_PAYHERO_STATUS=1
